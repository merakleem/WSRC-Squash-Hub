# Copy this file to .env and fill in the values before starting the server.
# .env is gitignored — never commit it.

# Required: Admin login password (choose something strong)
SITE_PASSWORD=

# Required: Long random string used to sign session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Required for email features (invite links, password resets, messaging players).
# Get your key from https://resend.com
RESEND_API_KEY=

# Optional overrides
# PORT=8080
# DB_PATH=./squash.db
# NODE_ENV=production
